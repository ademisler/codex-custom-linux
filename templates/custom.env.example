# Generic OpenAI-compatible provider environment.
# Copy into your custom CODEX_HOME and keep it private.

CUSTOM_CODEX_PROVIDER_NAME="openai-compatible"
CUSTOM_CODEX_API_BASE="https://api.example.com/v1"
CUSTOM_CODEX_API_KEY="replace-me"
CUSTOM_CODEX_MODEL="provider-model-id"
CUSTOM_CODEX_SUPPORTED_MODELS="provider-model-id,provider-model-fast"
CUSTOM_CODEX_PROXY_HOST="127.0.0.1"
CUSTOM_CODEX_PROXY_PORT="4007"
CUSTOM_CODEX_DEBUG_LOG="$HOME/.codex-custom-models/bridge-debug.log"

# Most providers accept max_completion_tokens. Some older compatible APIs expect
# max_tokens instead.
CUSTOM_CODEX_MAX_TOKENS_FIELD="max_completion_tokens"

# Optional JSON object merged into upstream request headers.
# CUSTOM_CODEX_UPSTREAM_HEADERS_JSON='{"x-provider-beta":"true"}'
