# MiniMax provider environment.
# Copy to ~/.codex-minimax/minimax.env and chmod 600.
# Never commit the edited file.

MINIMAX_API_KEY="replace-me"

CUSTOM_CODEX_PROVIDER_NAME="minimax"
CUSTOM_CODEX_API_BASE="https://api.minimax.io/v1"
CUSTOM_CODEX_API_KEY="$MINIMAX_API_KEY"
CUSTOM_CODEX_MODEL="MiniMax-M2.7"
CUSTOM_CODEX_SUPPORTED_MODELS="MiniMax-M2.7,MiniMax-M2.7-highspeed"
CUSTOM_CODEX_PROXY_HOST="127.0.0.1"
CUSTOM_CODEX_PROXY_PORT="4007"
CUSTOM_CODEX_DEBUG_LOG="$HOME/.codex-minimax/bridge-debug.log"
CUSTOM_CODEX_MAX_TOKENS_FIELD="max_completion_tokens"
